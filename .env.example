# Quant Monitor Desk — environment template
# Copy to .env and fill secrets locally. Never commit .env.

# =============================================================================
# 产品 live 总开关（24 源中除 web_search 真 API 延后外，公开源 E 类依赖此项）
# =============================================================================
QMD_ALLOW_LIVE_FETCH=

# =============================================================================
# 数据根目录 — 真网验证请保持隔离，避免写入 data/duckdb/quant_monitor.duckdb 主库
# 首次真网 execute 前在仓库根执行：
#   uv run python scripts/init_db.py --sync-registry
# =============================================================================
QMD_DATA_ROOT=.audit-sandbox/user-live

QMD_CONFIGS_ROOT=
QMD_RESOURCE_PROFILE=eco

# =============================================================================
# A. API Key / 身份（请手动填写；留空则对应源 live 会 fail-closed）
# =============================================================================

# fred — https://fred.stlouisfed.org/docs/api/api_key.html （32 位）
FRED_API_KEY=

# alpha_vantage — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# sec_edgar — 须含联系邮箱，例：QuantMonitorDesk contact@yourdomain.com
SEC_EDGAR_USER_AGENT=

# kalshi — 部分公开接口可无 key；遇 401/403 时填写
KALSHI_API_KEY=

# =============================================================================
# C. 预测市场 live smoke（配套 YAML：.audit-sandbox/round3h/prediction_market_live_authorization.yaml）
# 仅 smoke / 证据落盘，不写主库；与 qmd data live-fetch 产品路径可并存
# =============================================================================
KALSHI_LIVE_SMOKE=
POLYMARKET_LIVE_SMOKE=

# =============================================================================
# B. 本机 License / 券商 — 暂无资格时保持注释（不要取消注释去填）
# =============================================================================
# THS_IFIND_LICENSE_ARTIFACT=
# QMT_XTDATA_AUTHORIZED=
# XQSHARE_REMOTE_HOST=
# XQSHARE_REMOTE_PORT=
# QMT_XQSHARE_AUTHORIZED=

# =============================================================================
# F. web_search 真 API — Round4 后再做；本阶段勿配置搜索 API
# =============================================================================

# =============================================================================
# 以下遗留项 — 后端当前未接线，可忽略
# =============================================================================
# QMT_ACCOUNT=
# QMT_PASSWORD=
# EASTMONEY_TOKEN=
# YAHOO_PROXY=

# API 服务（本地开发）
QMD_API_HOST=127.0.0.1
QMD_API_PORT=8000

# Agent / 通知（与本批 live 无关，按需填写）
QMT_PASSWORD=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
WEBHOOK_URL=
