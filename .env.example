# Quant Monitor Desk — environment template
# Copy to .env and fill in only what you need. Keep secrets out of git.

# Resource profile: eco | normal | batch (default eco)
QMD_RESOURCE_PROFILE=eco

# Paths (defaults assume repo root)
# Leave empty to use defaults: QMD_DATA_ROOT -> <repo>/data, QMD_CONFIGS_ROOT -> <repo>/configs
QMD_DATA_ROOT=
QMD_CONFIGS_ROOT=

# API
QMD_API_HOST=127.0.0.1
QMD_API_PORT=8000

# Data sources — leave empty until needed; never commit real keys
FRED_API_KEY=
QMT_ACCOUNT=
QMT_PASSWORD=
EASTMONEY_TOKEN=
YAHOO_PROXY=

# Agent — read-only tools only; no auto-trading keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Notifications (Round 4)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
WEBHOOK_URL=
